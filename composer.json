{
    "name": "sodaho/container",
    "description": "Lightweight PSR-11 dependency injection container with autowiring and caching.",
    "type": "library",
    "license": "MIT",
    "keywords": ["container", "dependency-injection", "di", "psr-11", "autowiring", "php"],
    "require": {
        "php": "^8.2",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Sodaho\\Container\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sodaho\\Container\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Unit/Fixtures/TestFixtures.php",
            "tests/Integration/Fixtures/",
            "tests/Feature/Fixtures/"
        ],
        "exclude-from-classmap": [
            "tests/Unit/Fixtures/Php82/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "ci": ["@cs", "@analyse", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
